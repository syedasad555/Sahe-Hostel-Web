# MySQL — use a single connection URL (recommended)
DATABASE_URL=mysql://user:password@localhost:3306/hostel_management
# Alternative name (same as DATABASE_URL):
# MYSQL_URI=mysql://user:password@localhost:3306/hostel_management

# Docker MySQL container only (when using compose.yaml; match user/pass/db in DATABASE_URL)
# MYSQL_ROOT_PASSWORD=
# MYSQL_DATABASE=hostel_management
# MYSQL_USER=hostel
# MYSQL_PASSWORD=

# Server Configuration
PORT=5000
NODE_ENV=development
# Local uploads directory (defaults to project/uploads when unset)
# UPLOAD_DIR=

# Docker production (see project/.env.production.example beside compose.yaml)
# UPLOAD_DIR=/app/uploads
# PUBLIC_DIR=/app/public
# RUNNING_IN_CONTAINER=true

# Set to true in local dev so meal selection is always open (production: Tue & Sat 6am–6pm IST)
# MEAL_SELECTION_ALWAYS_OPEN=true

# Optional cross-origin origins (comma-separated). Production same-origin usually needs none.
# CORS_ORIGIN=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# System admin dashboard (separate from faculty login) — keep secret, never commit real values
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional: ADMIN_JWT_EXPIRE=8h

# System admin OTP for email/password updates
# OTP recipient can be a fixed security inbox.
ADMIN_OTP_TO_EMAIL=
ADMIN_OTP_FROM_EMAIL=
ADMIN_OTP_LENGTH=6
ADMIN_OTP_TTL_MS=120000
ADMIN_OTP_JWT_EXPIRE=2m

# Faculty credential update OTP (faculty login page). Falls back to ADMIN_OTP_* when unset.
# FACULTY_OTP_TO_EMAIL=
# FACULTY_OTP_FROM_EMAIL=
# FACULTY_OTP_LENGTH=6
# FACULTY_OTP_TTL_MS=120000
# FACULTY_OTP_JWT_EXPIRE=2m

# System health thresholds (set these in production to enable warning/critical labeling)
# Use ratios like 0.9 (90%) for heap thresholds.
ADMIN_HEAP_WARNING_RATIO=
ADMIN_HEAP_CRITICAL_RATIO=
ADMIN_CPU_PER_CORE_WARNING=
ADMIN_CPU_PER_CORE_CRITICAL=
ADMIN_API_UPTIME_WARNING_SECONDS=

# Password hashing cost for system admin updates
ADMIN_BCRYPT_COST=

# Email Configuration (for meal reports)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
# Gmail app password — use 16 chars with no spaces, or wrap in quotes if copied with spaces
EMAIL_PASS=your_app_password
# Optional: bypass flaky DNS (e.g. 192.178.211.108 for smtp.gmail.com)
# EMAIL_SMTP_HOST=
# Where daily meal reports are sent (defaults to EMAIL_USER if unset)
MEAL_REPORT_EMAIL=

# Initial faculty admin — used only when running: npm run seed-faculty (never commit real passwords)
# FACULTY_SEED_EMAIL=
# FACULTY_SEED_PASSWORD=
# FACULTY_SEED_NAME=
# FACULTY_SEED_EMPLOYEE_ID=
# FACULTY_SEED_DEPARTMENT=
# FACULTY_SEED_PHONE=
# Optional: FACULTY_SEED_DESIGNATION=Administrator
# Optional: FACULTY_SEED_RESET=true  (dev only — wipes faculty collection before seed)

# SaleSquared SMS — parent notifications (registration + outing)
# Docs: https://developer.salesquared.io/  (GET /sendsms/v1)
SALESQUARED_API_KEY=
SALESQUARED_SENDER_ID=
SALESQUARED_TEMPLATE_ID=
SALESQUARED_PE_ID=
# REQUIRED for delivery in India: paste exact DLT-approved template text from SaleSquared portal.
# Use {{name}}, {{year}}, {{id}} or {#name#}, {#year#}, {#id#} for variables.
# SALESQUARED_REGISTRATION_TEMPLATE=SAHE Hostelers: Dear Parent, {{name}}'s hostel registration is confirmed. Year: {{year}}. ID: {{id}}. Thank you.
# SALESQUARED_OUTING_TEMPLATE=Your Child had taken permission for outing from {{out}} and until {{in}} dates.
# SALESQUARED_UNICODE=0
