# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hostel-management

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Email Configuration (for meal reports)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Twilio — parent SMS (registration + outing notifications)
# Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number in E.164 (e.g. +14155552671). Required for sending SMS.
TWILIO_FROM_NUMBER=
