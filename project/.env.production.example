# Production deployment environment for Docker Compose
# Copy to .env beside compose.yaml on the college server.
# Never commit the real .env file.

NODE_ENV=production
PORT=5000
UPLOAD_DIR=/app/uploads
PUBLIC_DIR=/app/public
RUNNING_IN_CONTAINER=true

# App database connection
DATABASE_URL=mysql://hostel:replace_with_strong_db_password@mysql:3306/hostel_management

# Docker MySQL container bootstrap (must match user/pass/db in DATABASE_URL)
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=hostel_management
MYSQL_USER=hostel
MYSQL_PASSWORD=replace_with_strong_db_password

# Required — use a long random secret (min 16 characters)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d

# Required system admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_JWT_EXPIRE=8h

# Optional admin OTP for credential updates
ADMIN_OTP_TO_EMAIL=
ADMIN_OTP_FROM_EMAIL=
ADMIN_OTP_LENGTH=6
ADMIN_OTP_TTL_MS=120000
ADMIN_OTP_JWT_EXPIRE=2m

# Optional faculty OTP (falls back to ADMIN_OTP_* when unset)
# FACULTY_OTP_TO_EMAIL=
# FACULTY_OTP_FROM_EMAIL=

# Optional cross-origin access (comma-separated). Same-origin production usually needs none.
# CORS_ORIGIN=https://hostel.example.edu

# Email — meal reports (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
MEAL_REPORT_EMAIL=

# SMS — parent notifications (optional)
# SaleSquared SMS (registration + outing parent notifications)
SALESQUARED_API_KEY=
SALESQUARED_SENDER_ID=
# SALESQUARED_TEMPLATE_ID=

# Meal selection schedule uses Tue/Sat 6am–6pm IST by default
# MEAL_SELECTION_ALWAYS_OPEN=true

# Optional graceful shutdown timeout (milliseconds)
# SHUTDOWN_TIMEOUT_MS=10000
